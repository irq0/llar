{:update-max-retry 5
 :credentials-file "/var/lib/llar/credentials.edn"
 :runtime-config-dir "/var/lib/llar/config"
 :api {:dashboard {:port 9999 :enabled true}
       :reader {:port 8023 :enabled true}
       :podcast {:port 8024
                 :base-url "http://localhost:8024"
                 :video-format "bestvideo[height<=1080][ext=mp4][vcodec^=avc1]+bestaudio[ext=m4a]/bestvideo[height<=1080][ext=mp4]+bestaudio[ext=m4a]/best[height<=1080]"
                 :av-downloader-extra-args ["--embed-metadata"
                                            "--embed-chapters"
                                            "--write-subs"
                                            "--write-auto-subs"
                                            "--sub-langs" "en,en-orig,en-en,-live_chat"]
                 :retention {:default-episode-limit 25}}}
 :ui {:default-list-view {:storage :headlines
                          :shopping :headlines
                          :tweet :gallery}
      :favorites [[:all :default]
                  [:saved :item-tags]
                  [:highlight :item-tags]
                  [:in-progress :item-tags]
                  [:blog :source-tag]
                  [:hackernews :source-tag]
                  [:tech :source-tag]
                  [:deep-tech :source-tag]
                  [:sci :source-tag]
                  [:news :source-tag]
                  [:bookmark :type]
                  [:recreation :source-tag]]}
 :throttle {:command-max-concurrent 20
            :av-downloader-max-concurrent 2
            :streaming-max-concurrent 1}
 :timeouts {:readability 60
            :av-downloader 600
            :av-downloader-transcode 1800
            :html2text 30}
 :commands {:pandoc "pandoc"
            :w3m "w3m"
            :lynx "lynx"
            :av-downloader "yt-dlp"
            :html2text "html2text"}
 :blob-store-dir "/var/lib/llar/blobs"
 ;; Annotation export. Uncomment and configure to enable.
 ;; Zotero: add :zotero {:api-key "..." :user-id "..."} to credentials.edn
 ;; URL handler: opens a URL with {title}, {url}, {id}, {source}, {body} placeholders
 :export {:url-handler {:name "Org-roam"
                        :icon "fas fa-brain"
                        :template "org-protocol://roam-ref?template=R&ref={url}&title={title}&body={body}%0A%0A{source}%20%7C%20%F0%9F%96%96-id%3A{id}"}}
 }
